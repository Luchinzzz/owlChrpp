# Individual: :S1 (:S1)

ClassAssertion(:Student :S1)
ObjectPropertyAssertion(:is_studying :S1 :C1)
ObjectPropertyAssertion(:is_studying :S1 :C2)
DataPropertyAssertion(:grade :S1 "3.22"^^xsd:double)
DataPropertyAssertion(:name :S1 "Ahmed")

# Individual: :S2 (:S2)

ClassAssertion(:Student :S2)
ObjectPropertyAssertion(:is_studying :S2 :C3)
ObjectPropertyAssertion(:is_studying :S2 :C4)
DataPropertyAssertion(:grade :S2 "3.45"^^xsd:double)
DataPropertyAssertion(:name :S2 "Khaled")

# Individual: :S3 (:S3)

ClassAssertion(:Student :S3)
ObjectPropertyAssertion(:is_studying :S3 :C1)
ObjectPropertyAssertion(:is_studying :S3 :C5)
DataPropertyAssertion(:grade :S3 "3.7"^^xsd:double)
DataPropertyAssertion(:name :S3 "Manar")

# Individual: :TA1 (:TA1)

ClassAssertion(:TA :TA1)
ObjectPropertyAssertion(:belonging_to :TA1 :D1)
