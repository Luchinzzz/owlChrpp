AnnotationAssertion(rdfs:isDefinedBy odrl:spatial <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:spatial "spatial"@en)
AnnotationAssertion(vs:term_status odrl:spatial "testing")
SubDataPropertyOf(odrl:spatial odrl:rightOperand)

# Data Property: odrl:system (system)

AnnotationAssertion(rdfs:comment odrl:system "An identifiable computing system."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:system <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:system "system"@en)
AnnotationAssertion(vs:term_status odrl:system "testing")
SubDataPropertyOf(odrl:system odrl:rightOperand)

