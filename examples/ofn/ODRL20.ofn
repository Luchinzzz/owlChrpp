AnnotationAssertion(rdfs:isDefinedBy odrl:meteredTime <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:meteredTime "metered time"@en)
AnnotationAssertion(vs:term_status odrl:meteredTime "testing")
SubDataPropertyOf(odrl:meteredTime odrl:rightOperand)
