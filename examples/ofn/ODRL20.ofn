AnnotationAssertion(rdfs:label odrl:resolution "resolution"@en)
AnnotationAssertion(vs:term_status odrl:resolution "testing")
SubDataPropertyOf(odrl:resolution odrl:rightOperand)

# Data Property: odrl:rightOperand (right-operand)

AnnotationAssertion(rdfs:comment odrl:rightOperand "The operand applied to an instance of a constraint. Do not use the right-operand property directly within a Constraint. Instead, a Constraint instance must contain exactly one triple which makes use of one of the sub-properties of right-operand."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:rightOperand <http://www.w3.org/ns/odrl/2/>)
