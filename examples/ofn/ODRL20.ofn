AnnotationAssertion(rdfs:comment odrl:relativePosition "A point defined with reference to another position."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:relativePosition <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:relativePosition "relative position"@en)
