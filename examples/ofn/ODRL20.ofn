############################
#   Classes
############################

# Class: owl:Thing (owl:Thing)

EquivalentClasses(owl:Thing odrl:Asset)

# Class: odrl:Action (Action)

AnnotationAssertion(rdfs:comment odrl:Action "Instances of Action are things one might be permitted to do or prohibited from doing to a work."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Action <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Action "Action"@en)
AnnotationAssertion(vs:term_status odrl:Action "testing")
SubClassOf(odrl:Action skos:Concept)

# Class: odrl:Agreement (Agreement)

AnnotationAssertion(rdfs:comment odrl:Agreement "Policy expressions that are formal contracts (or licenses) stipulating all the terms of usage and all the parties involved."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Agreement <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Agreement "Agreement"@en)
AnnotationAssertion(vs:term_status odrl:Agreement "testing")
SubClassOf(odrl:Agreement odrl:Policy)
DisjointClasses(odrl:Agreement odrl:Offer)
DisjointClasses(odrl:Agreement odrl:Privacy)
DisjointClasses(odrl:Agreement odrl:Request)
DisjointClasses(odrl:Agreement odrl:Set)
DisjointClasses(odrl:Agreement odrl:Ticket)

# Class: odrl:All (All)

AnnotationAssertion(rdfs:comment odrl:All "Specifies that the scope of the relationship is all of the collective individuals within a context."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:All <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:All "All"@en)
AnnotationAssertion(vs:term_status odrl:All "testing")
SubClassOf(odrl:All odrl:Party)

# Class: odrl:All2ndConnections (All second-level connections)

AnnotationAssertion(rdfs:comment odrl:All2ndConnections "Specifies that the scope of the relationship is all of the second-level connections to the Party."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:All2ndConnections <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:All2ndConnections "All second-level connections"@en)
AnnotationAssertion(vs:term_status odrl:All2ndConnections "testing")
SubClassOf(odrl:All2ndConnections odrl:Party)

# Class: odrl:AllConnections (All connections)

AnnotationAssertion(rdfs:comment odrl:AllConnections "Specifies that the scope of the relationship is all of the first-level connections of the Party."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:AllConnections <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:AllConnections "All connections"@en)
AnnotationAssertion(vs:term_status odrl:AllConnections "testing")
SubClassOf(odrl:AllConnections odrl:Party)

# Class: odrl:AllGroups (All groups)

AnnotationAssertion(rdfs:comment odrl:AllGroups "Specifies that the scope of the relationship is all of the group connections of the Party."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:AllGroups <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:AllGroups "All groups"@en)
AnnotationAssertion(vs:term_status odrl:AllGroups "testing")
SubClassOf(odrl:AllGroups odrl:Party)

# Class: odrl:Asset (Asset)

AnnotationAssertion(rdfs:comment odrl:Asset "Asset is anything which can be subject to a policy. Asserting that something the target of a policy implies that it is an Asset."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Asset <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Asset "Asset"@en)
AnnotationAssertion(vs:term_status odrl:Asset "testing")

# Class: odrl:ConflictTerm (Conflict term)

AnnotationAssertion(rdfs:comment odrl:ConflictTerm "Instances of ConflictTerm describe policies for resolving conflicts."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:ConflictTerm <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:ConflictTerm "Conflict term"@en)
AnnotationAssertion(vs:term_status odrl:ConflictTerm "testing")

# Class: odrl:Constraint (Constraint)

AnnotationAssertion(rdfs:comment odrl:Constraint "Parent class of all Constraints."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Constraint <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Constraint "Constraint"@en)
AnnotationAssertion(vs:term_status odrl:Constraint "testing")
SubClassOf(odrl:Constraint owl:Thing)

# Class: odrl:Duty (Duty)

AnnotationAssertion(rdfs:comment odrl:Duty "A Duty is a rule which indicates requirements which must be fulfilled in order to receive the permission."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Duty <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Duty "Duty"@en)
AnnotationAssertion(vs:term_status odrl:Duty "testing")
SubClassOf(odrl:Duty odrl:Rule)
DisjointClasses(odrl:Duty odrl:Permission)
DisjointClasses(odrl:Duty odrl:Prohibition)

# Class: odrl:Group (Group)

AnnotationAssertion(rdfs:comment odrl:Group "Specifies that the scope of the relationship is the defined group with multiple individual members."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Group <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Group "Group"@en)
AnnotationAssertion(vs:term_status odrl:Group "testing")
SubClassOf(odrl:Group odrl:Party)

# Class: odrl:Individual (Individual)

AnnotationAssertion(rdfs:comment odrl:Individual "Specifies that the scope of the relationship is the single Party individual."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Individual <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Individual "Individual"@en)
AnnotationAssertion(vs:term_status odrl:Individual "testing")
SubClassOf(odrl:Individual odrl:Party)

# Class: odrl:Offer (Offer)

AnnotationAssertion(rdfs:comment odrl:Offer "An instance of Offer is a Policy expression that proposes terms of usage from an Asset owner."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Offer <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Offer "Offer"@en)
AnnotationAssertion(vs:term_status odrl:Offer "testing")
SubClassOf(odrl:Offer odrl:Policy)
DisjointClasses(odrl:Offer odrl:Privacy)
DisjointClasses(odrl:Offer odrl:Request)
DisjointClasses(odrl:Offer odrl:Set)
DisjointClasses(odrl:Offer odrl:Ticket)

# Class: odrl:Operator (Operator)

AnnotationAssertion(rdfs:comment odrl:Operator "Instances of the Operator class represent boolean operators"@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Operator <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Operator "Operator"@en)
AnnotationAssertion(vs:term_status odrl:Operator "testing")
SubClassOf(odrl:Operator owl:Thing)

# Class: odrl:Party (Party)

AnnotationAssertion(rdfs:comment odrl:Party "An entity which can participate in policy transactions. Use an instance of the Party class where it's necessary to associate a Scope with the relationship; in other cases, simply reference the party directly."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Party <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Party "Party"@en)
AnnotationAssertion(vs:term_status odrl:Party "testing")

# Class: odrl:Permission (Permission)

AnnotationAssertion(rdfs:comment odrl:Permission "A Permission is a rule which indicates the actions the assignee is permitted to perform on the associated asset. In other words, what the assigner (supplier) has granted to the assignee (consumer)."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Permission <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Permission "Permission"@en)
AnnotationAssertion(vs:term_status odrl:Permission "testing")
SubClassOf(odrl:Permission odrl:Rule)
DisjointClasses(odrl:Permission odrl:Prohibition)

# Class: odrl:Policy (Policy)

AnnotationAssertion(rdfs:comment odrl:Policy "A top level entity for describing policies."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Policy <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Policy "Policy"@en)
AnnotationAssertion(vs:term_status odrl:Policy "testing")
SubClassOf(odrl:Policy odrl:Asset)

# Class: odrl:Privacy (Privacy)

AnnotationAssertion(rdfs:comment odrl:Privacy "An instance of Privacy is a Policy expression that stipulates the terms of usage over personal information."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Privacy <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Privacy "Privacy"@en)
AnnotationAssertion(vs:term_status odrl:Privacy "testing")
SubClassOf(odrl:Privacy odrl:Policy)
DisjointClasses(odrl:Privacy odrl:Request)
DisjointClasses(odrl:Privacy odrl:Set)
DisjointClasses(odrl:Privacy odrl:Ticket)

# Class: odrl:Prohibition (Prohibition)

AnnotationAssertion(rdfs:comment odrl:Prohibition "A Prohibition is a rule which indicates the Actions that the assignee is prohibited to perform on the related Asset."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Prohibition <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Prohibition "Prohibition"@en)
AnnotationAssertion(vs:term_status odrl:Prohibition "testing")
SubClassOf(odrl:Prohibition odrl:Rule)

# Class: odrl:Request (Request)

AnnotationAssertion(rdfs:comment odrl:Request "An instance of Request is a Policy expression that proposes terms of usage to an Asset owner."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Request <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Request "Request"@en)
AnnotationAssertion(vs:term_status odrl:Request "testing")
SubClassOf(odrl:Request odrl:Policy)
DisjointClasses(odrl:Request odrl:Set)
DisjointClasses(odrl:Request odrl:Ticket)

# Class: odrl:Rule (Rule)

AnnotationAssertion(rdfs:comment odrl:Rule "An abstract common ancestor to Permissions, Prohibitions and Duties."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Rule <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Rule "Rule"@en)
AnnotationAssertion(vs:term_status odrl:Rule "testing")

# Class: odrl:Set (Set)

AnnotationAssertion(rdfs:comment odrl:Set "An instance of Set is a Policy expression that consists of entities from the complete model."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Set <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Set "Set"@en)
AnnotationAssertion(vs:term_status odrl:Set "testing")
SubClassOf(odrl:Set odrl:Policy)
DisjointClasses(odrl:Set odrl:Ticket)

# Class: odrl:Ticket (Ticket)

AnnotationAssertion(rdfs:comment odrl:Ticket "An instance of Ticket is a Policy expression that stipulates the terms of usage and is redeemable by any Party who currently holds the Ticket in their possession."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:Ticket <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:Ticket "Ticket"@en)
AnnotationAssertion(vs:term_status odrl:Ticket "testing")
SubClassOf(odrl:Ticket odrl:Policy)

# Class: odrl:UndefinedTerm (Undefined values)

AnnotationAssertion(rdfs:comment odrl:UndefinedTerm "Instances of UndefinedTerm describe policies for processing unsupported actions."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:UndefinedTerm <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:UndefinedTerm "Undefined values"@en)
AnnotationAssertion(vs:term_status odrl:UndefinedTerm "testing")


