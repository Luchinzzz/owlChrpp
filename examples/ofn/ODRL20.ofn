############################
#   Annotation Properties
############################

# Annotation Property: odrl:status (status)

AnnotationAssertion(rdfs:comment odrl:status "The current value of the constraint. The range of the status property is identical to that of the operand property selected used in the constraint."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:status <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:status "status"@en)
AnnotationAssertion(vs:term_status odrl:status "testing")
AnnotationPropertyDomain(odrl:status odrl:Constraint)


############################
#   Object Properties
############################

# Object Property: odrl:action (action)

AnnotationAssertion(rdfs:comment odrl:action "The operation relating to the asset for which permission is being granted. A permission must include exactly one action."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:action <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:action "action"@en)
AnnotationAssertion(vs:term_status odrl:action "testing")
ObjectPropertyDomain(odrl:action odrl:Rule)
ObjectPropertyRange(odrl:action odrl:Action)

# Object Property: odrl:assignee (assignee)

AnnotationAssertion(rdfs:comment odrl:assignee "The Party is the recipient of the policy statement."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:assignee <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:assignee "assignee"@en)
AnnotationAssertion(vs:term_status odrl:assignee "testing")
SubObjectPropertyOf(odrl:assignee odrl:function)
ObjectPropertyRange(odrl:assignee odrl:Party)

# Object Property: odrl:assigner (assigner)

AnnotationAssertion(rdfs:comment odrl:assigner "The Party is the issuer of the policy statement."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:assigner <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:assigner "assigner"@en)
AnnotationAssertion(vs:term_status odrl:assigner "testing")
SubObjectPropertyOf(odrl:assigner odrl:function)
ObjectPropertyRange(odrl:assigner odrl:Party)

# Object Property: odrl:attributedParty (attributed party)

AnnotationAssertion(rdfs:comment odrl:attributedParty "The Party to be attributed."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:attributedParty <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:attributedParty "attributed party"@en)
AnnotationAssertion(vs:term_status odrl:attributedParty "testing")
SubObjectPropertyOf(odrl:attributedParty odrl:function)

# Object Property: odrl:conflict (conflict)

AnnotationAssertion(rdfs:comment odrl:conflict "Relates a conflict-resolution mechansim to a Policy. If no mechanism is specified, the default is invalid."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:conflict <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:conflict "conflict"@en)
AnnotationAssertion(vs:term_status odrl:conflict "testing")
ObjectPropertyDomain(odrl:conflict odrl:Policy)
ObjectPropertyRange(odrl:conflict odrl:ConflictTerm)

# Object Property: odrl:consentingParty (consenting party)

AnnotationAssertion(rdfs:comment odrl:consentingParty "The Party to obtain consent from."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:consentingParty <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:consentingParty "consenting party"@en)
AnnotationAssertion(vs:term_status odrl:consentingParty "testing")
SubObjectPropertyOf(odrl:consentingParty odrl:function)

# Object Property: odrl:constraint (constraint)

AnnotationAssertion(rdfs:comment odrl:constraint "One or more constraints which affect the validity of the Permission; e.g. if the Action play is only permitted for a certain period of time."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:constraint <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:constraint "constraint"@en)
AnnotationAssertion(vs:term_status odrl:constraint "testing")
ObjectPropertyDomain(odrl:constraint odrl:Rule)
ObjectPropertyRange(odrl:constraint odrl:Constraint)

# Object Property: odrl:dateTime (date/time)

AnnotationAssertion(rdfs:comment odrl:dateTime "The date (and optional time and timezone) representing a point in time or period."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:dateTime <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:dateTime "date/time"@en)
AnnotationAssertion(vs:term_status odrl:dateTime "testing")
ObjectPropertyRange(odrl:dateTime ObjectUnionOf(xsd:date xsd:dateTime))

# Object Property: odrl:deliveryChannel (delivery channel)

AnnotationAssertion(rdfs:comment odrl:deliveryChannel "The delivery channel used for storing or communicating the asset."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:deliveryChannel <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:deliveryChannel "delivery channel"@en)
AnnotationAssertion(vs:term_status odrl:deliveryChannel "testing")

# Object Property: odrl:device (device)

AnnotationAssertion(rdfs:comment odrl:device "An identifiable computing system."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:device <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:device "device"@en)
AnnotationAssertion(vs:term_status odrl:device "testing")

# Object Property: odrl:duty (duty)

AnnotationAssertion(rdfs:comment odrl:duty "A Duty indicates requirements which must be fulfilled in order to receive the permission."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:duty <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:duty "duty"@en)
AnnotationAssertion(vs:term_status odrl:duty "testing")
ObjectPropertyDomain(odrl:duty odrl:Permission)
ObjectPropertyRange(odrl:duty ObjectUnionOf(odrl:Action odrl:Duty))

# Object Property: odrl:event (event)

AnnotationAssertion(rdfs:comment odrl:event "Specification of a defined event applicable to the asset usage."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:event <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:event "event"@en)
AnnotationAssertion(vs:term_status odrl:event "testing")

# Object Property: odrl:fileFormat (file format)

AnnotationAssertion(rdfs:comment odrl:fileFormat "The file format applicable to the Asset."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:fileFormat <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:fileFormat "file format"@en)
AnnotationAssertion(vs:term_status odrl:fileFormat "testing")

# Object Property: odrl:function (function)

AnnotationAssertion(rdfs:comment odrl:function "Function is an abstract property whose sub-properties define the roles which may be fulfilled by a party in relation to a Rule."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:function <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:function "function"@en)
AnnotationAssertion(vs:term_status odrl:function "testing")
ObjectPropertyDomain(odrl:function odrl:Rule)
ObjectPropertyRange(odrl:function odrl:Party)

# Object Property: odrl:informedParty (informed party)

AnnotationAssertion(rdfs:comment odrl:informedParty "The Party to be informed of all uses."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:informedParty <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:informedParty "informed party"@en)
AnnotationAssertion(vs:term_status odrl:informedParty "testing")
SubObjectPropertyOf(odrl:informedParty odrl:function)

# Object Property: odrl:inheritFrom (inherits from)

AnnotationAssertion(rdfs:comment odrl:inheritFrom "Relates a policy to another policy from which terms are inherited."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:inheritFrom <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:inheritFrom "inherits from"@en)
AnnotationAssertion(vs:term_status odrl:inheritFrom "testing")
ObjectPropertyDomain(odrl:inheritFrom odrl:Policy)
ObjectPropertyRange(odrl:inheritFrom odrl:Policy)

# Object Property: odrl:operator (operator)

AnnotationAssertion(rdfs:comment odrl:operator "The Boolean operator applied to a constraint and its operand."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:operator <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:operator "operator"@en)
AnnotationAssertion(vs:term_status odrl:operator "testing")
ObjectPropertyDomain(odrl:operator odrl:Constraint)
ObjectPropertyRange(odrl:operator odrl:Operator)

# Object Property: odrl:output (output)

AnnotationAssertion(rdfs:comment odrl:output "The output property specifies the Asset which is created from the output of the Action."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:output <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:output "output"@en)
AnnotationAssertion(vs:term_status odrl:output "testing")
SubObjectPropertyOf(odrl:output odrl:relation)
ObjectPropertyDomain(odrl:output odrl:Rule)
ObjectPropertyRange(odrl:output odrl:Asset)

# Object Property: odrl:payeeParty (payee party)

AnnotationAssertion(rdfs:comment odrl:payeeParty "The Party is the recipient of the payment."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:payeeParty <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:payeeParty "payee party"@en)
AnnotationAssertion(vs:term_status odrl:payeeParty "testing")
SubObjectPropertyOf(odrl:payeeParty odrl:function)

# Object Property: odrl:permission (permission)

AnnotationAssertion(rdfs:comment odrl:permission "Relates the description of an individual Permission to a Policy. A permission can be specified either in terms of an Action alone, or an instance of Permission relating an Action and one or more other attributes."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:permission <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:permission "permission"@en)
AnnotationAssertion(vs:term_status odrl:permission "testing")
ObjectPropertyDomain(odrl:permission odrl:Policy)
ObjectPropertyRange(odrl:permission ObjectUnionOf(odrl:Action odrl:Permission))

# Object Property: odrl:prohibition (prohibition)

AnnotationAssertion(rdfs:comment odrl:prohibition "Relates the description of an individual Prohibition to a Policy. A prohibition can be specified either in terms of an Action alone, or an instance of Prohibition relating an Action and one or more other attributes."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:prohibition <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:prohibition "prohibition"@en)
AnnotationAssertion(vs:term_status odrl:prohibition "testing")
ObjectPropertyDomain(odrl:prohibition odrl:Policy)
ObjectPropertyRange(odrl:prohibition ObjectUnionOf(odrl:Action odrl:Prohibition))

# Object Property: odrl:purpose (purpose)

AnnotationAssertion(rdfs:comment odrl:purpose "Specification of a defined purpose applicable to the asset usage."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:purpose <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:purpose "purpose"@en)
AnnotationAssertion(vs:term_status odrl:purpose "testing")

# Object Property: odrl:recipient (recipient)

AnnotationAssertion(rdfs:comment odrl:recipient "The party that receives the result of the Action on the Asset."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:recipient <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:recipient "recipient"@en)
AnnotationAssertion(vs:term_status odrl:recipient "testing")

# Object Property: odrl:relation (relation)

AnnotationAssertion(rdfs:comment odrl:relation "Relation is an abstract property which creates an explicit link between an Action and an Asset. Sub-properties of relation are used to define the nature of that link."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:relation <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:relation "relation"@en)
AnnotationAssertion(vs:term_status odrl:relation "testing")
ObjectPropertyDomain(odrl:relation odrl:Rule)
ObjectPropertyRange(odrl:relation odrl:Asset)

# Object Property: odrl:target (target)

AnnotationAssertion(rdfs:comment odrl:target "The target property specifies the Asset upon which the Action is performed."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:target <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:target "target"@en)
AnnotationAssertion(vs:term_status odrl:target "testing")
SubObjectPropertyOf(odrl:target odrl:relation)
ObjectPropertyDomain(odrl:target odrl:Rule)
ObjectPropertyRange(odrl:target odrl:Asset)

# Object Property: odrl:trackingParty (tracking party)

AnnotationAssertion(rdfs:comment odrl:trackingParty "The Party is the usage tracker."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:trackingParty <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:trackingParty "tracking party"@en)
AnnotationAssertion(vs:term_status odrl:trackingParty "testing")
SubObjectPropertyOf(odrl:trackingParty odrl:function)

# Object Property: odrl:undefined (undefined)

AnnotationAssertion(rdfs:comment odrl:undefined "Relates the mechanism used for handling undefined actions to a Policy. If no mechanism is specified, the default is invalid."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:undefined <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:undefined "undefined"@en)
AnnotationAssertion(vs:term_status odrl:undefined "testing")
ObjectPropertyDomain(odrl:undefined odrl:Policy)
ObjectPropertyRange(odrl:undefined odrl:UndefinedTerm)

# Object Property: odrl:unit (unit)

AnnotationAssertion(rdfs:comment odrl:unit "The unit of measurement used for the constraint value."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:unit <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:unit "unit"@en)
AnnotationAssertion(vs:term_status odrl:unit "testing")
ObjectPropertyDomain(odrl:unit odrl:Constraint)
ObjectPropertyRange(odrl:unit rdfs:Resource)

# Object Property: odrl:version (version)

AnnotationAssertion(rdfs:comment odrl:version "The scope of versions for the asset."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:version <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:version "version"@en)
AnnotationAssertion(vs:term_status odrl:version "testing")

# Object Property: odrl:virtualLocation (virtual location)

AnnotationAssertion(rdfs:comment odrl:virtualLocation "Specification of a digital locale."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:virtualLocation <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:virtualLocation "virtual location"@en)
AnnotationAssertion(vs:term_status odrl:virtualLocation "testing")


############################
#   Data Properties
############################

# Data Property: odrl:absolutePosition (absolute position)

AnnotationAssertion(rdfs:comment odrl:absolutePosition "A point defined with absolute coordinates."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:absolutePosition <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:absolutePosition "absolute position"@en)
AnnotationAssertion(vs:term_status odrl:absolutePosition "testing")
SubDataPropertyOf(odrl:absolutePosition odrl:rightOperand)

# Data Property: odrl:absoluteSize (absolute size)

AnnotationAssertion(rdfs:comment odrl:absoluteSize "The absolute dimension that the Asset may be resized."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:absoluteSize <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:absoluteSize "absolute size"@en)
AnnotationAssertion(vs:term_status odrl:absoluteSize "testing")
SubDataPropertyOf(odrl:absoluteSize odrl:rightOperand)
DataPropertyRange(odrl:absoluteSize xsd:decimal)

# Data Property: odrl:count (count)

AnnotationAssertion(rdfs:comment odrl:count "The numeric count indicating the number of times the corresponding entity may be exercised"@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:count <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:count "count"@en)
AnnotationAssertion(vs:term_status odrl:count "testing")
SubDataPropertyOf(odrl:count odrl:rightOperand)
DataPropertyRange(odrl:count xsd:nonNegativeInteger)

# Data Property: odrl:dateTime (date/time)

SubDataPropertyOf(odrl:dateTime odrl:rightOperand)

# Data Property: odrl:deliveryChannel (delivery channel)

SubDataPropertyOf(odrl:deliveryChannel odrl:rightOperand)

