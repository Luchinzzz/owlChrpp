AnnotationAssertion(vs:term_status odrl:payAmount "testing")
SubDataPropertyOf(odrl:payAmount odrl:rightOperand)
DataPropertyRange(odrl:payAmount xsd:decimal)

# Data Property: odrl:percentage (percentage)

AnnotationAssertion(rdfs:comment odrl:percentage "The amount (as a percentage) of the action applicable to the asset."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:percentage <http://www.w3.org/ns/odrl/2/>)
