# Individual: odrl:acceptTracking (Accept tracking)

AnnotationAssertion(rdfs:comment odrl:acceptTracking "The act of accepting that the use of the asset may be recorded. The collected information may be tracked by the assigner, or may link to a Party with role function 'trackingParty'."@en)
AnnotationAssertion(rdfs:isDefinedBy odrl:acceptTracking <http://www.w3.org/ns/odrl/2/>)
AnnotationAssertion(rdfs:label odrl:acceptTracking "Accept tracking"@en)
AnnotationAssertion(vs:term_status odrl:acceptTracking "testing")
ClassAssertion(skos:Concept odrl:acceptTracking)
ClassAssertion(odrl:Action odrl:acceptTracking)

